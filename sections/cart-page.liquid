<div class="cart-page">
  <h1 class="cart-title">Your <span class="accent">Cart</span></h1>

  {%- if cart.item_count == 0 -%}
    <div class="cart-empty">
      <p class="cart-empty-msg">Your cart is empty.</p>
      <a href="/collections/all" class="btn-primary">Continue Shopping</a>
    </div>
  {%- else -%}
    <div class="cart-items">
      {%- for item in cart.items -%}
        <div class="cart-item">
          <div class="cart-item-image">
            {%- if item.image -%}
              <img src="{{ item.image | img_url: '200x200', crop: 'center' }}"
                   alt="{{ item.image.alt | default: item.title | escape }}"
                   width="100" height="100" loading="lazy">
            {%- endif -%}
          </div>

          <div class="cart-item-details">
            <h3 class="cart-item-title">
              <a href="{{ item.url }}">{{ item.product.title }}</a>
            </h3>
            {%- unless item.variant.title == 'Default Title' -%}
              <p class="cart-item-variant">{{ item.variant.title }}</p>
            {%- endunless -%}

            <div class="cart-item-prices">
              <span class="product-price">{{ item.final_price | money }}</span>
              {%- assign li_cap = item.original_price -%}
              {%- assign li_pr = item.final_price -%}
              {%- unless li_cap == nil or li_cap == blank or li_cap == "" -%}
                {%- if li_cap > li_pr -%}
                  <span class="price-old">{{ li_cap | money }}</span>
                {%- endif -%}
              {%- endunless -%}
            </div>

            <div class="cart-item-actions">
              <div class="cart-qty">
                <a href="/cart/change?line={{ forloop.index }}&amp;quantity={{ item.quantity | minus: 1 }}"
                   class="cart-qty-btn" aria-label="Decrease quantity">−</a>
                <span class="cart-qty-num">{{ item.quantity }}</span>
                <a href="/cart/change?line={{ forloop.index }}&amp;quantity={{ item.quantity | plus: 1 }}"
                   class="cart-qty-btn" aria-label="Increase quantity">+</a>
              </div>
              <a href="/cart/change?line={{ forloop.index }}&amp;quantity=0"
                 class="cart-remove" aria-label="Remove item">Remove</a>
            </div>
          </div>

          <div class="cart-item-total">
            {{ item.final_line_price | money }}
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="cart-summary">
      <div class="cart-subtotal">
        <span>Subtotal</span>
        <span>{{ cart.total_price | money }}</span>
      </div>
      <p class="cart-note">Shipping and taxes calculated at checkout.</p>
      <form action="/checkout" method="post">
        <button type="submit" class="btn-primary btn-checkout">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
          Proceed to Checkout
        </button>
      </form>
      <a href="/collections/all" class="cart-continue">← Continue Shopping</a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Cart Page",
  "settings": [],
  "presets": [
    {
      "name": "Cart Page"
    }
  ]
}
{% endschema %}
