{%- assign s = section.settings -%}

<section
  id="password-content-{{ section.id }}"
  class="password-content"
>
  <div class="password-content__inner">

    <!-- Logo / Shop Name -->
    <div class="password-content__brand">
      {%- if shop.logo -%}
        <img
          src="{{ shop.logo | image_url: width: 240 }}"
          alt="{{ shop.name | escape }}"
          class="password-content__logo"
          width="240"
          loading="eager"
        >
      {%- else -%}
        <span class="password-content__shop-name">{{ shop.name | escape }}</span>
      {%- endif -%}
    </div>

    <!-- Heading & Message -->
    {%- if s.title != blank -%}
      <h1 class="password-content__title">{{ s.title | escape }}</h1>
    {%- endif -%}

    {%- if s.message != blank -%}
      <p class="password-content__message">{{ s.message | escape }}</p>
    {%- endif -%}

    <!-- Password Form -->
    <div class="password-content__login-form">
      {%- form 'storefront_password', id: 'storefront-password-form-{{ section.id }}', class: 'password-form' -%}
        {%- if form.errors -%}
          <p class="password-form__error" role="alert">
            {{ 'password.wrong_password' | t | default: "The password you entered is incorrect." }}
          </p>
        {%- endif -%}

        <div class="password-form__field-group">
          <label for="password-input-{{ section.id }}" class="visually-hidden">
            {{ 'password.password_label' | t | default: "Password" }}
          </label>
          <input
            id="password-input-{{ section.id }}"
            type="password"
            name="password"
            class="password-form__input"
            placeholder="{{ 'password.placeholder' | t | default: 'Enter password' }}"
            autocomplete="current-password"
            required
            aria-required="true"
          >
          <button type="submit" class="password-form__submit btn btn--primary">
            {{ 'password.submit' | t | default: "Enter" }}
          </button>
        </div>
      {%- endform -%}
    </div>

    <!-- Newsletter Signup -->
    {%- if s.show_newsletter -%}
      <div class="password-content__newsletter">
        <p class="password-content__newsletter-label">
          {{ 'password.newsletter_label' | t | default: "Get notified when we launch:" }}
        </p>
        {%- form 'customer', id: 'password-newsletter-form-{{ section.id }}', class: 'password-newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">

          {%- if form.posted_successfully? -%}
            <p class="password-newsletter-form__success" role="status">
              {{ 'newsletter.success' | t | default: "Thanks! We'll be in touch." }}
            </p>
          {%- else -%}
            {%- if form.errors -%}
              <p class="password-newsletter-form__error" role="alert">
                {{ form.errors.translated_fields['email'] | capitalize }}
                {{ form.errors.messages['email'] }}
              </p>
            {%- endif -%}
            <div class="password-newsletter-form__group">
              <label for="newsletter-pw-email-{{ section.id }}" class="visually-hidden">
                {{ 'newsletter.email_label' | t | default: "Email address" }}
              </label>
              <input
                id="newsletter-pw-email-{{ section.id }}"
                type="email"
                name="contact[email]"
                class="password-form__input"
                placeholder="{{ 'newsletter.email_placeholder' | t | default: 'your@email.com' }}"
                required
                autocomplete="email"
              >
              <button type="submit" class="password-form__submit btn btn--secondary">
                {{ 'newsletter.button_label' | t | default: "Notify Me" }}
              </button>
            </div>
          {%- endif -%}
        {%- endform -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  #password-content-{{ section.id }} {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-page-bg, #fff);
    padding: 3rem var(--page-gutter, 1.5rem);
  }

  #password-content-{{ section.id }} .password-content__inner {
    max-width: 500px;
    width: 100%;
    text-align: center;
  }

  #password-content-{{ section.id }} .password-content__brand {
    margin-bottom: 2rem;
  }

  #password-content-{{ section.id }} .password-content__logo {
    max-width: 200px;
    height: auto;
    display: inline-block;
  }

  #password-content-{{ section.id }} .password-content__shop-name {
    font-family: var(--font-heading, inherit);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-color, #111);
  }

  #password-content-{{ section.id }} .password-content__title {
    font-family: var(--font-heading, inherit);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--text-color, #111);
    margin: 0 0 1rem;
    line-height: 1.2;
  }

  #password-content-{{ section.id }} .password-content__message {
    font-size: 1.0625rem;
    color: var(--text-color-muted, #555);
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  #password-content-{{ section.id }} .password-content__login-form {
    margin-bottom: 2.5rem;
  }

  #password-content-{{ section.id }} .password-form__field-group,
  #password-content-{{ section.id }} .password-newsletter-form__group {
    display: flex;
    gap: 0.5rem;
  }

  #password-content-{{ section.id }} .password-form__input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid var(--input-border, #ccc);
    border-radius: var(--input-radius, 4px);
    background: var(--input-bg, #fff);
    color: var(--text-color, #111);
    font-size: 1rem;
    transition: border-color 0.2s ease;
  }

  #password-content-{{ section.id }} .password-form__input:focus {
    outline: none;
    border-color: var(--primary, #222);
  }

  #password-content-{{ section.id }} .password-form__submit {
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    border: none;
    border-radius: var(--btn-radius, 4px);
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  #password-content-{{ section.id }} .btn--primary {
    background: var(--primary, #222);
    color: var(--color-btn-text, #fff);
  }

  #password-content-{{ section.id }} .btn--secondary {
    background: transparent;
    color: var(--primary, #222);
    border: 2px solid var(--primary, #222);
  }

  #password-content-{{ section.id }} .password-form__submit:hover {
    opacity: 0.85;
  }

  #password-content-{{ section.id }} .password-form__error {
    color: var(--color-error, #b91c1c);
    font-size: 0.9rem;
    margin: 0 0 0.75rem;
  }

  #password-content-{{ section.id }} .password-content__newsletter-label {
    font-size: 0.9375rem;
    color: var(--text-color-muted, #555);
    margin: 0 0 0.75rem;
  }

  #password-content-{{ section.id }} .password-newsletter-form__success {
    color: var(--status-success-text, #065f46);
    font-size: 1rem;
    font-weight: 500;
  }

  #password-content-{{ section.id }} .password-newsletter-form__error {
    color: var(--color-error, #b91c1c);
    font-size: 0.875rem;
    margin: 0 0 0.5rem;
  }

  .visually-hidden {
    position: absolute !important;
    width: 1px; height: 1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  @media (max-width: 480px) {
    #password-content-{{ section.id }} .password-form__field-group,
    #password-content-{{ section.id }} .password-newsletter-form__group {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "Password Page",
  "tag": "section",
  "class": "section-password-content",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Opening Soon"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "Message",
      "default": "We're working on something amazing. Enter the password to get early access."
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show Newsletter Signup",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Password Page"
    }
  ]
}
{% endschema %}
