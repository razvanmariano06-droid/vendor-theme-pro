<section
  id="customer-reset-password-{{ section.id }}"
  class="customer-reset-password account-section"
>
  <div class="account-section__inner">
    <h1 class="account-section__title">
      {{ 'customer.reset_password.title' | t | default: "Reset Your Password" }}
    </h1>

    <p class="account-section__description">
      {{ 'customer.reset_password.subheading' | t | default: "Enter a new password for your account." }}
    </p>

    {%- form 'reset_customer_password', id: 'reset-password-form-{{ section.id }}', class: 'account-form' -%}
      {%- if form.errors -%}
        <div class="account-form__errors" role="alert" aria-live="assertive">
          <ul>
            {%- for error in form.errors -%}
              <li>
                {%- if error == 'form' -%}
                  {{ form.errors.messages[error] }}
                {%- else -%}
                  {{ form.errors.translated_fields[error] | capitalize }}
                  {{ form.errors.messages[error] }}
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="account-form__field">
        <label for="reset-password-{{ section.id }}" class="account-form__label">
          {{ 'customer.reset_password.password' | t | default: "New Password" }}
          <span class="account-form__required" aria-hidden="true">*</span>
        </label>
        <input
          id="reset-password-{{ section.id }}"
          type="password"
          name="customer[password]"
          class="account-form__input"
          autocomplete="new-password"
          required
          aria-required="true"
          autofocus
        >
      </div>

      <div class="account-form__field">
        <label for="reset-password-confirm-{{ section.id }}" class="account-form__label">
          {{ 'customer.reset_password.password_confirm' | t | default: "Confirm New Password" }}
          <span class="account-form__required" aria-hidden="true">*</span>
        </label>
        <input
          id="reset-password-confirm-{{ section.id }}"
          type="password"
          name="customer[password_confirmation]"
          class="account-form__input"
          autocomplete="new-password"
          required
          aria-required="true"
        >
      </div>

      <button type="submit" class="account-form__submit btn btn--primary btn--full">
        {{ 'customer.reset_password.submit' | t | default: "Reset Password" }}
      </button>
    {%- endform -%}

    <p class="account-section__login-link">
      <a href="/account/login">{{ 'customer.reset_password.back_to_login' | t | default: "← Back to Sign In" }}</a>
    </p>
  </div>
</section>

<style>
  #customer-reset-password-{{ section.id }} {
    padding: var(--section-padding-top, 4rem) var(--page-gutter, 1.5rem) var(--section-padding-bottom, 4rem);
  }

  #customer-reset-password-{{ section.id }} .account-section__inner {
    max-width: 480px;
    margin: 0 auto;
  }

  #customer-reset-password-{{ section.id }} .account-section__title {
    font-family: var(--font-heading, inherit);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--text-color, #111);
    margin: 0 0 0.5rem;
    text-align: center;
  }

  #customer-reset-password-{{ section.id }} .account-section__description {
    text-align: center;
    color: var(--text-color-muted, #555);
    font-size: 0.9375rem;
    margin: 0 0 1.75rem;
  }

  #customer-reset-password-{{ section.id }} .account-form__field {
    margin-bottom: 1.25rem;
  }

  #customer-reset-password-{{ section.id }} .account-form__label {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-color, #111);
    margin-bottom: 0.4rem;
  }

  #customer-reset-password-{{ section.id }} .account-form__required {
    color: var(--color-error, #b91c1c);
    margin-left: 2px;
  }

  #customer-reset-password-{{ section.id }} .account-form__input {
    display: block;
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--input-border, #ccc);
    border-radius: var(--input-radius, 4px);
    background: var(--input-bg, #fff);
    color: var(--text-color, #111);
    font-size: 1rem;
    transition: border-color 0.2s ease;
    box-sizing: border-box;
  }

  #customer-reset-password-{{ section.id }} .account-form__input:focus {
    outline: none;
    border-color: var(--primary, #222);
  }

  #customer-reset-password-{{ section.id }} .account-form__submit {
    width: 100%;
    padding: 0.875rem;
    background: var(--primary, #222);
    color: var(--color-btn-text, #fff);
    border: none;
    border-radius: var(--btn-radius, 4px);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s ease;
    margin-top: 0.5rem;
  }

  #customer-reset-password-{{ section.id }} .account-form__submit:hover {
    opacity: 0.88;
  }

  #customer-reset-password-{{ section.id }} .account-form__errors {
    background: var(--color-error-bg, #fef2f2);
    border: 1px solid var(--color-error-border, #fca5a5);
    border-radius: 4px;
    padding: 0.75rem 1rem;
    margin-bottom: 1.25rem;
    color: var(--color-error, #b91c1c);
    font-size: 0.9rem;
  }

  #customer-reset-password-{{ section.id }} .account-form__errors ul {
    margin: 0;
    padding: 0 0 0 1.2rem;
  }

  #customer-reset-password-{{ section.id }} .account-form__errors ul li:only-child {
    list-style: none;
    padding: 0;
  }

  #customer-reset-password-{{ section.id }} .account-section__login-link {
    margin-top: 1.5rem;
    text-align: center;
    font-size: 0.9375rem;
  }

  #customer-reset-password-{{ section.id }} .account-section__login-link a {
    color: var(--primary, #222);
    text-decoration: underline;
  }
</style>

{% schema %}
{
  "name": "Reset Password",
  "tag": "section",
  "class": "section-customer-reset-password",
  "settings": [],
  "presets": [
    {
      "name": "Reset Password"
    }
  ]
}
{% endschema %}
