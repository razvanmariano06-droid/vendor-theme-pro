{% paginate search.results by section.settings.results_per_page %}

<div class="search-results-section" data-section-id="{{ section.id }}">
  <div class="container">

    {%- comment -%} Search form at top, pre-filled with current query {%- endcomment -%}
    <div class="search-results__form-wrapper">
      <form action="/search" method="get" class="search-results__form" role="search">
        <label class="search-results__form-label" for="search-input-{{ section.id }}">
          {{ 'general.search.title' | t }}
        </label>
        <div class="search-results__input-group">
          <input
            type="search"
            id="search-input-{{ section.id }}"
            name="q"
            value="{{ search.terms | escape }}"
            class="search-results__input"
            placeholder="{{ 'general.search.placeholder' | t }}"
            autocomplete="off"
            spellcheck="false"
            aria-label="{{ 'general.search.title' | t }}"
          >
          <input type="hidden" name="type" value="product,article,page">
          <button type="submit" class="search-results__submit btn btn--primary" aria-label="{{ 'general.search.submit' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 104.15 4.15a7.5 7.5 0 0012.5 12.5z"/>
            </svg>
            <span class="visually-hidden">{{ 'general.search.submit' | t }}</span>
          </button>
        </div>
      </form>
    </div>

    {%- if search.performed -%}

      {%- if search.results_count > 0 -%}

        <p class="search-results__count">
          {{ 'general.search.results_with_count_and_term' | t: count: search.results_count, terms: search.terms }}
        </p>

        <div class="search-results__grid">
          {%- for item in search.results -%}
            {%- case item.object_type -%}
              {%- when 'product' -%}
                {% render 'product-card', product: item, index: forloop.index0 %}
              {%- when 'article' -%}
                <article class="search-result-card search-result-card--article">
                  {%- if item.image -%}
                    <a href="{{ item.url }}" class="search-result-card__image-link" tabindex="-1">
                      <div class="search-result-card__image-wrapper">
                        <img
                          src="{{ item.image | img_url: '400x300', crop: 'center' }}"
                          alt="{{ item.image.alt | default: item.title | escape }}"
                          class="search-result-card__image"
                          loading="lazy"
                          width="400"
                          height="300"
                        >
                      </div>
                    </a>
                  {%- endif -%}
                  <div class="search-result-card__body">
                    <span class="search-result-card__type">{{ 'general.search.type.article' | t }}</span>
                    <h2 class="search-result-card__title">
                      <a href="{{ item.url }}">{{ item.title }}</a>
                    </h2>
                    {%- if item.excerpt != blank -%}
                      <p class="search-result-card__excerpt">{{ item.excerpt | strip_html | truncate: 120 }}</p>
                    {%- endif -%}
                  </div>
                </article>
              {%- when 'page' -%}
                <div class="search-result-card search-result-card--page">
                  <div class="search-result-card__body">
                    <span class="search-result-card__type">{{ 'general.search.type.page' | t }}</span>
                    <h2 class="search-result-card__title">
                      <a href="{{ item.url }}">{{ item.title }}</a>
                    </h2>
                    {%- if item.content != blank -%}
                      <p class="search-result-card__excerpt">{{ item.content | strip_html | truncate: 120 }}</p>
                    {%- endif -%}
                  </div>
                </div>
            {%- endcase -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          {% render 'pagination', paginate: paginate %}
        {%- endif -%}

      {%- else -%}

        <div class="search-results__empty">
          <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 104.15 4.15a7.5 7.5 0 0012.5 12.5z"/>
          </svg>
          <h2 class="search-results__empty-heading">
            {{ 'general.search.no_results_title' | t: terms: search.terms }}
          </h2>
          <p class="search-results__empty-text">{{ 'general.search.no_results_html' | t: terms: search.terms }}</p>
        </div>

      {%- endif -%}

    {%- else -%}

      <div class="search-results__prompt">
        <p>{{ 'general.search.search_for_something' | t }}</p>
      </div>

    {%- endif -%}

  </div>
</div>

{% endpaginate %}

<style>
  .search-results-section { padding: 48px 0; }
  .search-results__form-wrapper {
    max-width: 680px;
    margin: 0 auto 40px;
  }
  .search-results__form-label {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-color);
    margin-bottom: 12px;
    text-align: center;
  }
  .search-results__input-group {
    display: flex;
    border: 2px solid var(--border-color, #ddd);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .search-results__input-group:focus-within { border-color: var(--primary); }
  .search-results__input {
    flex: 1;
    border: none;
    padding: 12px 18px;
    font-size: 1rem;
    color: var(--text-color);
    background: var(--background, #fff);
    outline: none;
  }
  .search-results__submit {
    background: var(--primary);
    color: var(--primary-text, #fff);
    border: none;
    padding: 12px 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    transition: opacity 0.2s;
    border-radius: 0;
  }
  .search-results__submit:hover { opacity: 0.9; }
  .search-results__count {
    color: var(--text-muted, var(--text-color));
    font-size: 0.95rem;
    margin-bottom: 24px;
  }
  .search-results__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  @media (max-width: 1024px) { .search-results__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 768px)  { .search-results__grid { grid-template-columns: repeat(2, 1fr); gap: 16px; } }
  @media (max-width: 480px)  { .search-results__grid { grid-template-columns: 1fr; } }
  .search-result-card {
    background: var(--card-background, var(--background, #fff));
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s;
  }
  .search-result-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.12); }
  .search-result-card__image-wrapper {
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }
  .search-result-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  .search-result-card:hover .search-result-card__image { transform: scale(1.03); }
  .search-result-card__body { padding: 16px 18px; }
  .search-result-card__type {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--primary);
    margin-bottom: 6px;
  }
  .search-result-card__title {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 6px;
  }
  .search-result-card__title a {
    color: var(--text-color);
    text-decoration: none;
  }
  .search-result-card__title a:hover { color: var(--primary); }
  .search-result-card__excerpt {
    font-size: 0.82rem;
    color: var(--text-muted, var(--text-color));
    line-height: 1.5;
    margin: 0;
  }
  .search-results__empty {
    text-align: center;
    padding: 60px 24px;
    color: var(--text-muted, var(--text-color));
  }
  .search-results__empty svg { display: inline-block; margin-bottom: 20px; }
  .search-results__empty-heading {
    font-size: 1.4rem;
    color: var(--text-color);
    margin-bottom: 10px;
  }
  .search-results__empty-text { font-size: 0.95rem; }
  .search-results__prompt {
    text-align: center;
    padding: 40px 0;
    color: var(--text-muted, var(--text-color));
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>

{% schema %}
{
  "name": "Search Results",
  "settings": [
    {
      "type": "range",
      "id": "results_per_page",
      "label": "Results per page",
      "min": 8,
      "max": 48,
      "step": 8,
      "default": 16
    }
  ]
}
{% endschema %}
