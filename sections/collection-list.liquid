<div class="collection-list-section" data-section-id="{{ section.id }}">
  <div class="container">

    {%- if section.settings.title != blank -%}
      <h1 class="collection-list__heading">{{ section.settings.title }}</h1>
    {%- endif -%}

    {%- assign collections_to_show = collections -%}

    {%- if collections_to_show.size > 0 -%}
      <div
        class="collection-list__grid"
        style="--grid-columns: {{ section.settings.columns }};"
      >
        {%- for collection in collections_to_show -%}
          <a
            href="{{ collection.url }}"
            class="collection-card"
            aria-label="{{ collection.title }}"
          >
            <div class="collection-card__image-wrapper">
              {%- if collection.image -%}
                <img
                  src="{{ collection.image | img_url: '600x400', crop: 'center' }}"
                  alt="{{ collection.image.alt | default: collection.title | escape }}"
                  class="collection-card__image"
                  loading="lazy"
                  width="600"
                  height="400"
                >
              {%- elsif collection.products.first and collection.products.first.featured_image -%}
                <img
                  src="{{ collection.products.first.featured_image | img_url: '600x400', crop: 'center' }}"
                  alt="{{ collection.title | escape }}"
                  class="collection-card__image"
                  loading="lazy"
                  width="600"
                  height="400"
                >
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'collection-card__placeholder' }}
              {%- endif -%}
            </div>

            <div class="collection-card__info">
              <h2 class="collection-card__title">{{ collection.title }}</h2>
              <p class="collection-card__count">
                {{ 'collections.general.items_with_count' | t: count: collection.products_count }}
              </p>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="collection-list__empty">
        <p>{{ 'collections.general.no_collections' | t }}</p>
      </div>
    {%- endif -%}

  </div>
</div>

<style>
  .collection-list-section { padding: 48px 0; }
  .collection-list__heading {
    font-size: 2rem;
    color: var(--text-color);
    margin: 0 0 32px;
    text-align: center;
  }
  .collection-list__grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns, 3), 1fr);
    gap: 28px;
  }
  @media (max-width: 768px) {
    .collection-list__grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  }
  @media (max-width: 480px) {
    .collection-list__grid { grid-template-columns: 1fr; }
  }
  .collection-card {
    display: block;
    text-decoration: none;
    border-radius: 10px;
    overflow: hidden;
    background: var(--card-background, var(--background, #fff));
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .collection-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }
  .collection-card__image-wrapper {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 2;
  }
  .collection-card__image,
  .collection-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .collection-card:hover .collection-card__image { transform: scale(1.04); }
  .collection-card__info {
    padding: 16px 20px;
  }
  .collection-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-color);
    margin: 0 0 4px;
  }
  .collection-card__count {
    font-size: 0.875rem;
    color: var(--text-muted, var(--text-color));
    margin: 0;
  }
  .collection-list__empty {
    text-align: center;
    padding: 60px 0;
    color: var(--text-muted, var(--text-color));
  }
</style>

{% schema %}
{
  "name": "Collections List",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "All Collections"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Collections per row",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    }
  ]
}
{% endschema %}
