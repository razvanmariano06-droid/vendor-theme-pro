<div class="error-404-section" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="error-404__inner">

      <p class="error-404__code" aria-hidden="true">404</p>

      <h1 class="error-404__title">
        {{ section.settings.title | default: 'general.404.title' | t }}
      </h1>

      <p class="error-404__message">
        {{ section.settings.message | default: 'general.404.subtext' | t }}
      </p>

      <div class="error-404__search">
        <p class="error-404__search-label">{{ 'general.404.search_hint' | t }}</p>
        <form action="/search" method="get" class="error-404__search-form" role="search">
          <input type="hidden" name="type" value="product">
          <div class="error-404__search-group">
            <input
              type="search"
              name="q"
              class="error-404__search-input"
              placeholder="{{ 'general.search.placeholder' | t }}"
              autocomplete="off"
              aria-label="{{ 'general.search.title' | t }}"
            >
            <button
              type="submit"
              class="error-404__search-submit btn btn--primary"
              aria-label="{{ 'general.search.submit' | t }}"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35m0 0A7.5 7.5 0 104.15 4.15a7.5 7.5 0 0012.5 12.5z"/>
              </svg>
            </button>
          </div>
        </form>
      </div>

      <a href="/" class="error-404__home-btn btn btn--primary">
        {{ 'general.404.home_button' | t }}
      </a>

    </div>
  </div>
</div>

<style>
  .error-404-section {
    padding: 80px 0 96px;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  .error-404__inner {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }
  .error-404__code {
    font-size: clamp(6rem, 20vw, 10rem);
    font-weight: 900;
    line-height: 1;
    color: var(--primary);
    opacity: 0.18;
    margin: 0 0 -24px;
    letter-spacing: -0.04em;
    user-select: none;
  }
  .error-404__title {
    font-size: clamp(1.6rem, 4vw, 2.5rem);
    color: var(--text-color);
    margin: 0 0 16px;
    line-height: 1.25;
  }
  .error-404__message {
    font-size: 1.05rem;
    color: var(--text-muted, var(--text-color));
    line-height: 1.6;
    margin: 0 0 40px;
  }
  .error-404__search { margin-bottom: 32px; }
  .error-404__search-label {
    font-size: 0.9rem;
    color: var(--text-muted, var(--text-color));
    margin-bottom: 10px;
  }
  .error-404__search-group {
    display: flex;
    border: 2px solid var(--border-color, #ddd);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .error-404__search-group:focus-within { border-color: var(--primary); }
  .error-404__search-input {
    flex: 1;
    border: none;
    padding: 12px 18px;
    font-size: 1rem;
    color: var(--text-color);
    background: var(--background, #fff);
    outline: none;
  }
  .error-404__search-submit {
    background: var(--primary);
    color: var(--primary-text, #fff);
    border: none;
    padding: 12px 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    transition: opacity 0.2s;
    border-radius: 0;
  }
  .error-404__search-submit:hover { opacity: 0.9; }
  .error-404__home-btn {
    display: inline-block;
    padding: 14px 36px;
    background: var(--primary);
    color: var(--primary-text, #fff);
    border-radius: 6px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .error-404__home-btn:hover { opacity: 0.9; }
</style>

{% schema %}
{
  "name": "404 Page",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Page Not Found"
    },
    {
      "type": "textarea",
      "id": "message",
      "label": "Message",
      "default": "The page you're looking for doesn't exist."
    }
  ]
}
{% endschema %}
