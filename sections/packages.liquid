<section class="packages-section" id="packages">
  <div class="section-header">
    <h2 class="section-title">{{ section.settings.title }}</h2>
    <p class="section-subtitle">{{ section.settings.subtitle }}</p>
  </div>

  <div class="products-grid">
    {%- assign packages_collection = collections[section.settings.collection] -%}
    {%- if packages_collection != blank and packages_collection.products.size > 0 -%}
      {%- assign products_limit = section.settings.products_per_page -%}
      {%- for product in packages_collection.products limit: products_limit -%}
        <div class="product-card anim-fade-up">
          <a href="{{ product.url }}" class="product-card-image-link">
            <div class="product-card-image-wrap">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}"
                     alt="{{ product.featured_image.alt | default: product.title | escape }}"
                     width="600" height="600" loading="lazy">
              {%- else -%}
                <div class="product-card-no-image">{{ product.title | upcase | truncate: 2, '' }}</div>
              {%- endif -%}
            </div>
          </a>

          <div class="product-card-body">
            <h3 class="product-card-title">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h3>

            {%- assign cap = product.compare_at_price -%}
            {%- assign pr = product.price -%}
            <div class="product-card-prices">
              <span class="product-price">{{ pr | money }}</span>
              {%- unless cap == nil or cap == blank or cap == "" or cap == 0 -%}
                {%- if cap > pr -%}
                  <span class="product-compare-price">{{ cap | money }}</span>
                {%- endif -%}
              {%- endunless -%}
            </div>

            {%- unless cap == nil or cap == blank or cap == "" or cap == 0 -%}
              {%- if cap > pr -%}
                <div class="sale-tag">SALE</div>
              {%- endif -%}
            {%- endunless -%}

            <div class="product-card-actions">
              <button class="cart-icon-btn"
                      data-product-id="{{ product.variants.first.id }}"
                      data-product-url="{{ product.url }}"
                      aria-label="Add to cart">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
              </button>
              <a href="{{ product.url }}" class="buy-now-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
                BUY NOW
              </a>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..4) -%}
        <div class="product-card anim-fade-up">
          <div class="product-card-image-wrap">
            <div class="product-card-no-image">P{{ i }}</div>
          </div>
          <div class="product-card-body">
            <h3 class="product-card-title">Reseller Package {{ i }}</h3>
            <div class="product-card-prices">
              <span class="product-price">$49.00</span>
              <span class="product-compare-price">$99.00</span>
            </div>
            <div class="sale-tag">SALE</div>
            <div class="product-card-actions">
              <button class="cart-icon-btn" aria-label="Add to cart">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
              </button>
              <a href="/collections/all" class="buy-now-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
                BUY NOW
              </a>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Packages",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Choose Your Package"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Everything you need to start reselling today"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products to show",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Packages",
      "settings": {
        "title": "Choose Your Package",
        "subtitle": "Everything you need to start reselling today"
      }
    }
  ]
}
{% endschema %}
