<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_background }}">

    <title>{{ 'gift_cards.issued.title' | t: value: gift_card.initial_value | money_without_trailing_zeros | strip_html }} &mdash; {{ shop.name }}</title>

    <meta name="description" content="{{ 'gift_cards.issued.subtext' | t }}">
    <meta property="og:title" content="{{ 'gift_cards.issued.title' | t: value: gift_card.initial_value | money_without_trailing_zeros | strip_html }} &mdash; {{ shop.name }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ request.origin }}{{ gift_card.url }}">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {% render 'css-variables' %}

    {{ 'theme.css' | asset_url | stylesheet_tag }}

    <style>
      /*! Gift card page styles */
      :root {
        --color-gift-bg: #1a1a2e;
        --color-gift-card: #16213e;
        --color-gift-accent: #e94560;
        --color-gift-text: #eaeaea;
        --color-gift-muted: #a0a0b0;
        --radius-gift-card: 16px;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background-color: var(--color-gift-bg);
        color: var(--color-gift-text);
        font-family: var(--font-body-family, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem 1rem;
      }

      .gift-card__shop-name {
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-gift-muted);
        margin-bottom: 1.5rem;
        text-align: center;
      }

      .gift-card__wrapper {
        background: var(--color-gift-card);
        border-radius: var(--radius-gift-card);
        padding: 2.5rem 2rem;
        max-width: 480px;
        width: 100%;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
        text-align: center;
      }

      .gift-card__image-wrapper {
        margin-bottom: 1.75rem;
      }

      .gift-card__image {
        width: 100%;
        max-width: 340px;
        height: auto;
        border-radius: 10px;
        display: block;
        margin: 0 auto;
      }

      .gift-card__heading {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 0.375rem;
        color: var(--color-gift-text);
      }

      .gift-card__subheading {
        font-size: 0.9375rem;
        color: var(--color-gift-muted);
        margin-bottom: 2rem;
      }

      .gift-card__amount {
        display: inline-block;
        font-size: 2.25rem;
        font-weight: 800;
        color: var(--color-gift-accent);
        margin-bottom: 1.75rem;
        line-height: 1;
      }

      .gift-card__amount--spent {
        font-size: 1rem;
        font-weight: 400;
        color: var(--color-gift-muted);
        display: block;
        margin-top: 0.25rem;
      }

      .gift-card__code-label {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--color-gift-muted);
        margin-bottom: 0.5rem;
      }

      .gift-card__code-wrapper {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 8px;
        padding: 0.875rem 1rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
      }

      .gift-card__code {
        font-family: 'Courier New', Courier, monospace;
        font-size: 1.375rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        color: var(--color-gift-text);
        word-break: break-all;
        cursor: text;
        user-select: all;
      }

      .gift-card__copy-btn {
        background: none;
        border: none;
        cursor: pointer;
        color: var(--color-gift-muted);
        padding: 0.25rem;
        border-radius: 4px;
        transition: color 0.2s ease;
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
      }

      .gift-card__copy-btn:hover,
      .gift-card__copy-btn:focus-visible {
        color: var(--color-gift-text);
        outline: none;
      }

      .gift-card__expiry {
        font-size: 0.875rem;
        color: var(--color-gift-muted);
        margin-bottom: 2rem;
      }

      .gift-card__expiry strong {
        color: var(--color-gift-text);
      }

      .gift-card__expired-badge {
        display: inline-block;
        background: var(--color-gift-accent);
        color: #fff;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.25rem 0.6rem;
        border-radius: 4px;
        margin-bottom: 1rem;
      }

      .gift-card__actions {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .gift-card__btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.875rem 1.5rem;
        border-radius: 8px;
        font-size: 0.9375rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        border: none;
        transition: opacity 0.2s ease, transform 0.15s ease;
        width: 100%;
      }

      .gift-card__btn:hover {
        opacity: 0.88;
        transform: translateY(-1px);
      }

      .gift-card__btn--primary {
        background: var(--color-gift-accent);
        color: #fff;
      }

      .gift-card__btn--secondary {
        background: rgba(255, 255, 255, 0.08);
        color: var(--color-gift-text);
        border: 1px solid rgba(255, 255, 255, 0.14);
      }

      .gift-card__qr {
        margin: 1.75rem auto 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
      }

      .gift-card__qr-label {
        font-size: 0.75rem;
        color: var(--color-gift-muted);
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .gift-card__qr canvas,
      .gift-card__qr img {
        border-radius: 6px;
        background: #fff;
        padding: 6px;
      }

      .gift-card__copy-success {
        font-size: 0.8125rem;
        color: #4ade80;
        height: 1.2em;
        text-align: center;
        margin-top: -0.75rem;
        margin-bottom: 0.5rem;
        opacity: 0;
        transition: opacity 0.3s ease;
      }

      .gift-card__copy-success.is-visible {
        opacity: 1;
      }

      @media print {
        body {
          background: #fff;
          color: #000;
        }

        .gift-card__wrapper {
          background: #fff;
          box-shadow: none;
          border: 1px solid #ddd;
          color: #000;
        }

        .gift-card__actions {
          display: none;
        }
      }
    </style>
  </head>

  <body>
    <p class="gift-card__shop-name">{{ shop.name }}</p>

    <main class="gift-card__wrapper" id="gift-card" aria-label="{{ 'gift_cards.issued.title' | t: value: gift_card.initial_value | money_without_trailing_zeros | strip_html }}">

      {%- comment -%} Gift card image {%- endcomment -%}
      <div class="gift-card__image-wrapper">
        {%- if gift_card.product.featured_image -%}
          <img
            class="gift-card__image"
            src="{{ gift_card.product.featured_image | image_url: width: 680 }}"
            alt="{{ gift_card.product.featured_image.alt | escape }}"
            width="680"
            height="{{ 680 | divided_by: gift_card.product.featured_image.aspect_ratio | round }}"
            loading="eager"
          >
        {%- else -%}
          {{ 'gift-card' | placeholder_svg_tag: 'gift-card__image' }}
        {%- endif -%}
      </div>

      {%- comment -%} Heading and subtext {%- endcomment -%}
      <h1 class="gift-card__heading">{{ 'gift_cards.issued.title' | t: value: gift_card.initial_value | money_without_trailing_zeros }}</h1>
      <p class="gift-card__subheading">{{ 'gift_cards.issued.subtext' | t }}</p>

      {%- comment -%} Gift card value {%- endcomment -%}
      <div class="gift-card__amount">
        {%- if gift_card.balance != gift_card.initial_value -%}
          <span aria-label="{{ 'gift_cards.issued.remaining_html' | t: balance: gift_card.balance | money | strip_html }}">
            {{ gift_card.balance | money }}
          </span>
          <span class="gift-card__amount--spent">
            {{ 'gift_cards.issued.remaining_html' | t: balance: gift_card.initial_value | money }}
          </span>
        {%- else -%}
          <span>{{ gift_card.initial_value | money }}</span>
        {%- endif -%}
      </div>

      {%- comment -%} Expired badge {%- endcomment -%}
      {%- unless gift_card.enabled -%}
        <p class="gift-card__expired-badge">{{ 'gift_cards.issued.expired' | t }}</p>
      {%- endunless -%}

      {%- comment -%} Gift card code {%- endcomment -%}
      <p class="gift-card__code-label">{{ 'gift_cards.issued.gift_card_code' | t }}</p>
      <div class="gift-card__code-wrapper">
        <span
          id="gift-card-code"
          class="gift-card__code"
          aria-label="{{ 'gift_cards.issued.gift_card_code' | t }}: {{ gift_card.code | replace: '-', ' - ' }}"
        >{{ gift_card.code | format_code }}</span>

        <button
          class="gift-card__copy-btn"
          id="gift-card-copy-btn"
          type="button"
          aria-label="{{ 'gift_cards.issued.copy_code' | t }}"
          data-gift-card-copy
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </button>
      </div>
      <p class="gift-card__copy-success" id="gift-card-copy-success" role="status" aria-live="polite">
        {{ 'gift_cards.issued.copy_code_success' | t }}
      </p>

      {%- comment -%} Expiry date {%- endcomment -%}
      {%- if gift_card.expires_on -%}
        <p class="gift-card__expiry">
          {%- assign expiry_date = gift_card.expires_on | date: '%B %-d, %Y' -%}
          {{ 'gift_cards.issued.expiration_date' | t: expiration: expiry_date }}
        </p>
      {%- endif -%}

      {%- comment -%} QR code {%- endcomment -%}
      <div class="gift-card__qr" id="gift-card-qr">
        <span class="gift-card__qr-label">{{ 'gift_cards.issued.qr_image_alt' | t }}</span>
        <div id="gift-card-qr-code" data-identifier="{{ gift_card.qr_identifier }}"></div>
      </div>

      {%- comment -%} Actions {%- endcomment -%}
      <div class="gift-card__actions">
        <a
          href="{{ shop.url }}"
          class="gift-card__btn gift-card__btn--primary"
          target="_blank"
          rel="noopener"
        >
          {{ 'gift_cards.issued.shop_link' | t }}
        </a>

        <button
          type="button"
          class="gift-card__btn gift-card__btn--secondary"
          onclick="window.print();"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 6 2 18 2 18 9"></polyline>
            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
            <rect x="6" y="14" width="12" height="8"></rect>
          </svg>
          {{ 'gift_cards.issued.print_gift_card' | t }}
        </button>
      </div>
    </main>

    {%- comment -%} QR code library via Shopify CDN {%- endcomment -%}
    <script src="{{ 'vendor/qrcode.js' | shopify_asset_url }}" defer></script>

    <script>
      (function () {
        // QR code generation
        document.addEventListener('DOMContentLoaded', function () {
          var qrTarget = document.getElementById('gift-card-qr-code');
          if (qrTarget && typeof QRCode !== 'undefined') {
            var identifier = qrTarget.getAttribute('data-identifier');
            new QRCode(qrTarget, {
              text: identifier,
              width: 120,
              height: 120,
              colorDark: '#000000',
              colorLight: '#ffffff',
              correctLevel: QRCode.CorrectLevel.M
            });
          }

          // Copy code to clipboard
          var copyBtn = document.getElementById('gift-card-copy-btn');
          var copySuccess = document.getElementById('gift-card-copy-success');
          var codeEl = document.getElementById('gift-card-code');

          if (copyBtn && codeEl) {
            copyBtn.addEventListener('click', function () {
              var code = codeEl.textContent.trim();
              if (navigator.clipboard) {
                navigator.clipboard.writeText(code).then(showCopySuccess);
              } else {
                // Fallback for older browsers
                var temp = document.createElement('textarea');
                temp.value = code;
                temp.style.position = 'absolute';
                temp.style.left = '-9999px';
                document.body.appendChild(temp);
                temp.select();
                document.execCommand('copy');
                document.body.removeChild(temp);
                showCopySuccess();
              }
            });
          }

          function showCopySuccess() {
            if (!copySuccess) return;
            copySuccess.classList.add('is-visible');
            setTimeout(function () {
              copySuccess.classList.remove('is-visible');
            }, 2500);
          }
        });
      })();
    </script>
  </body>
</html>
