{%- comment -%} Usage: {% render 'empty-state', icon: '🛒', title: 'Cart is Empty', message: 'Add items to continue', link: '/', link_text: 'Shop Now' %} {%- endcomment -%}
<div class="empty-state">
  <div class="empty-state__icon">{{ icon | default: '📦' }}</div>
  <h2 class="empty-state__title">{{ title | default: 'Nothing here yet' }}</h2>
  {%- if message != blank -%}
    <p class="empty-state__message">{{ message }}</p>
  {%- endif -%}
  {%- if link != blank and link_text != blank -%}
    <a href="{{ link }}" class="btn btn--primary">{{ link_text }}</a>
  {%- endif -%}
</div>
