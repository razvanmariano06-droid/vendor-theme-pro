{%- comment -%} Usage: {% render 'image-lazy', image: image, alt: 'alt text', width: 400 %} {%- endcomment -%}
{%- if image -%}
  {%- assign img_width = width | default: 400 -%}
  {%- assign img_2x = img_width | times: 2 -%}
  <img
    src="{{ image | img_url: img_width | append: 'x' }}"
    srcset="{{ image | img_url: img_width | append: 'x' }} 1x, {{ image | img_url: img_2x | append: 'x' }} 2x"
    alt="{{ alt | default: image.alt | escape }}"
    width="{{ image.width }}"
    height="{{ image.height }}"
    loading="lazy"
    class="lazy-img"
    style="pointer-events:none;"
  >
{%- endif -%}
