<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="{% if request.locale.direction == 'rtl' %}rtl{% else %}ltr{% endif %}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>{{ shop.name }} &ndash; {{ 'general.password_page.opening_soon' | t }}</title>

  <meta name="description" content="{{ shop.description | escape }}">

  {%- comment -%} CSS Variables from theme settings {%- endcomment -%}
  <style>
    {%- render 'css-variables' -%}

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html,
    body {
      height: 100%;
    }

    body {
      background-color: var(--color-background, #0a0a0a);
      color: var(--color-foreground, #ffffff);
      font-family: var(--font-body-family, sans-serif);
      font-size: var(--font-body-size, 16px);
      font-weight: var(--font-body-weight, 400);
      line-height: 1.6;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    .password-header {
      padding: 2rem;
      text-align: center;
    }

    .password-header__logo {
      font-family: var(--font-heading-family, serif);
      font-size: clamp(1.5rem, 4vw, 2.5rem);
      font-weight: var(--font-heading-weight, 700);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--color-foreground, #ffffff);
      text-decoration: none;
    }

    main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .password-footer {
      padding: 1.5rem 2rem;
      text-align: center;
      font-size: 0.8125rem;
      color: color-mix(in srgb, var(--color-foreground, #ffffff) 50%, transparent);
      border-top: 1px solid color-mix(in srgb, var(--color-foreground, #ffffff) 10%, transparent);
    }

    .password-footer a {
      color: inherit;
      text-decoration: underline;
    }

    .password-footer a:hover {
      color: var(--color-foreground, #ffffff);
    }
  </style>

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>

<body class="template-password">

  <header class="password-header" role="banner">
    <a href="/" class="password-header__logo" aria-label="{{ shop.name }}">
      {%- if settings.logo_image != blank -%}
        {%- assign logo_alt = settings.logo_image.alt | default: shop.name | escape -%}
        {{
          settings.logo_image
          | image_url: width: 400
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            alt: logo_alt,
            class: 'password-header__logo-image',
            widths: '100, 150, 200, 250, 300, 400',
            sizes: '(min-width: 768px) 200px, 140px'
        }}
      {%- else -%}
        {{ settings.logo_text | default: shop.name | escape }}
      {%- endif -%}
    </a>
  </header>

  <main id="main-content" role="main" tabindex="-1">
    {%- sections 'password-content' -%}
    {{ content_for_layout }}
  </main>

  <footer class="password-footer" role="contentinfo">
    <p>
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}.
      {%- if shop.powered_by_link -%}
        &nbsp;{{ shop.powered_by_link }}
      {%- endif -%}
    </p>
  </footer>

</body>
</html>
